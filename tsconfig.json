{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "outDir": "./out",
    "rootDir": "./src",
    "strict": false,                  // Set to true once you fix existing type warnings
    "types": ["vscode", "node"],      // Required due to the new empty-by-default behavior
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".vscode-test"]
}
